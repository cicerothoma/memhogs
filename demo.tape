# Renders the README demo gif. Regenerate with: vhs demo.tape
Output docs/demo.gif

Set FontSize 15
Set Width 1080
Set Height 620
Set Padding 18
Set TypingSpeed 55ms
Set Theme "Builtin Dark"

Type "memhogs --top 3"
Sleep 600ms
Enter
Sleep 4s

Type "memhogs --compact --top 6"
Sleep 400ms
Enter
Sleep 3.5s

Type "memhogs slack"
Sleep 400ms
Enter
Sleep 4.5s
